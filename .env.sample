# Application
# Core host identity, listening endpoints, TLS, and filesystem roots.
APP_ENV=development
APP_NAME=codexsun
APP_HOST=0.0.0.0
APP_DOMAIN=127.0.0.1
APP_HTTP_PORT=4174
APP_HTTPS_PORT=3443
WEB_ROOT=dist
CLOUDFLARE_ENABLED=false
TLS_ENABLED=false

# Frontend
# Frontend domain and host values used by the shared application shell.
FRONTEND_DOMAIN=127.0.0.1
FRONTEND_HOST=127.0.0.1
FRONTEND_HTTP_PORT=4173
FRONTEND_HTTPS_PORT=5174
VITE_FRONTEND_TARGET=shop

# Toasts
# Global toast placement and visual tone used by the shared application feedback layer.
VITE_TOAST_POSITION=top-right
VITE_TOAST_TONE=soft

# Developer Settings
# Internal developer and refactor aids that should remain hidden during normal business usage.
VITE_SHOW_DEVOPS_NAMES=false

# Database
# Primary runtime storage using MariaDB by default, with PostgreSQL available for supported deployments.
DB_DRIVER=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=codexsun_db
DB_USER=root
DB_PASSWORD=change-me
DB_SSL=false

# Analytics
# Optional analytics database connection used for reporting or secondary workloads.
ANALYTICS_DB_ENABLED=false
ANALYTICS_DB_HOST=127.0.0.1
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=codexsun_analytics
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=
ANALYTICS_DB_SSL=false

# Security
# JWT, login limits, secret ownership, and internal access policy values.
JWT_SECRET=change-this-secret-to-at-least-16-characters
JWT_EXPIRES_IN_SECONDS=28800
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=30
ADMIN_SESSION_IDLE_MINUTES=30
ADMIN_ALLOWED_IPS=
INTERNAL_API_ALLOWED_IPS=
SECRET_ROTATION_DAYS=90
SECRETS_LAST_ROTATED_AT=
SECRET_OWNER_EMAIL=
OPERATIONS_OWNER_EMAIL=
SUPER_ADMIN_EMAILS=admin@example.com

# Observability
# Application log level and operator alert thresholds for commerce and connector health.
APP_LOG_LEVEL=info
OPS_ALERT_EMAILS=
OPS_ALERT_WEBHOOK_URL=
ALERT_CHECKOUT_FAILURE_THRESHOLD=5
ALERT_PAYMENT_VERIFY_FAILURE_THRESHOLD=3
ALERT_WEBHOOK_FAILURE_THRESHOLD=3
ALERT_ORDER_CREATION_FAILURE_THRESHOLD=5
ALERT_MAIL_FAILURE_THRESHOLD=10
ALERT_CONNECTOR_SYNC_FAILURE_THRESHOLD=3

# Operations
# Backup cadence, restore verification, audit logging, and security review checkpoints.
SERVER_MONITOR_SHARED_SECRET=
DB_BACKUP_ENABLED=true
DB_BACKUP_CADENCE_HOURS=24
DB_BACKUP_RETENTION_DAYS=14
DB_BACKUP_MAX_FILES=5
DB_BACKUP_LAST_VERIFIED_AT=
GDRIVE_BACKUP_ENABLED=false
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_FOLDER_ID=
ADMIN_AUDIT_LOG_ENABLED=true
SUPPORT_EVENT_LOG_ENABLED=true
SECURITY_CHECKLIST_LAST_REVIEWED_AT=

# Auth
# OTP behavior and elevated-access defaults for the shared authentication flow.
AUTH_OTP_DEBUG=false
AUTH_OTP_EXPIRY_MINUTES=10

# Notifications
# SMTP values used for OTP, recovery, and outbound system email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Codexsun

# Commerce Storefront
# Storefront shipping thresholds and default commerce checkout values.
ECOMMERCE_FREE_SHIPPING_THRESHOLD=3999
ECOMMERCE_DEFAULT_SHIPPING_AMOUNT=149
ECOMMERCE_PRICE_PURCHASE_TO_MRP_PERCENT=150
ECOMMERCE_PRICE_PURCHASE_TO_SELL_PERCENT=75

# Razorpay
# Payment gateway credentials for the ecommerce checkout surface.
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_BUSINESS_NAME=Codexsun
RAZORPAY_CHECKOUT_IMAGE=
RAZORPAY_THEME_COLOR=#1f2937
PAYMENT_TEST=false

# Billing
# Shared billing year and statutory integration settings.
BILLING_FINANCIAL_YEAR_START_MONTH=4
BILLING_FINANCIAL_YEAR_START_DAY=1
BILLING_LOCK_DATE=
BILLING_PERIOD_CLOSED_THROUGH=
BILLING_DOCUMENT_NUMBERING_POLICY=hybrid
BILLING_REVIEW_ENABLED=true
BILLING_REVIEW_THRESHOLD_AMOUNT=50000
BILLING_STOCK_VALUATION_METHOD=weighted_average

# Billing Prefixes
# Document prefix controls used by billing auto-numbering across finance documents.
BILLING_PREFIX_PAYMENT=PAY
BILLING_PREFIX_RECEIPT=RCP
BILLING_PREFIX_SALES=SAL
BILLING_PREFIX_SALES_RETURN=SRT
BILLING_PREFIX_CREDIT_NOTE=CRN
BILLING_PREFIX_PURCHASE=PUR
BILLING_PREFIX_PURCHASE_RETURN=PRT
BILLING_PREFIX_DEBIT_NOTE=DBN
BILLING_PREFIX_STOCK_ADJUSTMENT=STA
BILLING_PREFIX_LANDED_COST=LCT
BILLING_PREFIX_CONTRA=CON
BILLING_PREFIX_JOURNAL=JRN

# E-Invoice
# GST e-invoice provider credentials and mode selection.
BILLING_EINVOICE_ENABLED=false
BILLING_EINVOICE_MODE=manual
BILLING_EINVOICE_BASE_URL=
BILLING_EINVOICE_USERNAME=
BILLING_EINVOICE_PASSWORD=
BILLING_EINVOICE_CLIENT_ID=
BILLING_EINVOICE_CLIENT_SECRET=
BILLING_EINVOICE_GSTIN=

# E-Way Bill
# E-way bill provider credentials and mode selection.
BILLING_EWAYBILL_ENABLED=false
BILLING_EWAYBILL_MODE=manual
BILLING_EWAYBILL_BASE_URL=
BILLING_EWAYBILL_USERNAME=
BILLING_EWAYBILL_PASSWORD=
BILLING_EWAYBILL_CLIENT_ID=
BILLING_EWAYBILL_CLIENT_SECRET=
BILLING_EWAYBILL_GSTIN=

# Container Startup
# Used by .container/setup.sh and containerized startup/update flows.
GIT_SYNC_ENABLED=true
GIT_AUTO_UPDATE_ON_START=false
GIT_FORCE_UPDATE_ON_START=true
GIT_SCHEDULED_UPDATE_ENABLED=false
GIT_SCHEDULED_UPDATE_CADENCE_MINUTES=30
GIT_SCHEDULED_UPDATE_AUTO_APPLY=false
GIT_REPOSITORY_URL=https://github.com/CODEXSUN/codexsun.git
GIT_BRANCH=main
INSTALL_DEPS_ON_START=false
BUILD_ON_START=false

# Deployment Update
# Manual production update stays host-side: npm run deploy:update
# API updates remain disabled until CODEXSUN_UPDATE_COMMAND and a secret are set.
CODEXSUN_UPDATE_SECRET=
CODEXSUN_UPDATE_COMMAND=
CODEXSUN_UPDATE_TIMEOUT_MS=600000
CODEXSUN_COMPOSE_FILE=.container/clients/codexsun/docker-compose.yml
IMAGE_TAG=codexsun:v2
TARGET_ENV=local
APP_HTTP_HOST_PORT=4173

# Frappe
FRAPPE_ENABLED=true
FRAPPE_BASE_URL=https://erp.thetirupurtextiles.com
FRAPPE_SITE_NAME=thetirupurtextiles
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
FRAPPE_TIMEOUT_SECONDS=15
FRAPPE_DEFAULT_COMPANY="The Tirupur Textiles"
FRAPPE_DEFAULT_WAREHOUSE="Tirupur Direct - Retail - TTT"
