{
  "name": "@codexsun/app-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rimraf dist .turbo && rimraf --glob \"*.tsbuildinfo\"",
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "approve-build": "vite build --config vite.config.ts && echo 'Build approved!'",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.17.0",
    "@vitejs/plugin-react-swc": "4.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "recharts": "^3.1.2",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^4.1.13",
    "axios": "^1.11.0",
    "chart.js": "^4.4.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
