{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.backend.tsbuildinfo",
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023"],
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@codexsun/core": ["packages/core/src/index.ts"],
      "@codexsun/core/*": ["packages/core/src/*"],
      "@cxsun/*": ["cxsun/src/*"]
    },
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "cxsun/src/**/*.ts",
    "apps/api/src/**/*.ts",
    "apps/cli/src/**/*.ts",
    "apps/sites/src/**/*.ts",
    "apps/sites/shared/**/*.ts"
  ]
}
