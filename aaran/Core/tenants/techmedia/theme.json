{
    "colors": {
        "primary": "#8F1F8D",
        "secondary": "#111111",
        "accent": "#F5A623",
        "background": "#FFFFFF",
        "surface": "#F9FAFB",
        "text": "#1F2937",
        "muted": "#6B7280",

        "menu_bg": "#FFFFFF",
        "menu_text": "#111111",
        "menu_hover": "#8F1F8D",

        "footer_bg": "#111111",
        "footer_text": "#FFFFFF",

        "button_bg": "#8F1F8D",
        "button_text": "#FFFFFF"
    },

    "typography": {
        "font_family": "Poppins, sans-serif",
        "heading_weight": "600",
        "body_weight": "400"
    },

    "logos": {
        "menu": {
            "default": "/assets/techmedia/logo/logo-light.svg",
            "scrolled": "/assets/techmedia/logo/logo-dark.svg",

            "sizes": {
                "mobile": {
                    "width": 110,
                    "height": 32
                },
                "desktop": {
                    "width": 160,
                    "height": 48
                }
            }
        },

        "animation": {
            "logo_transition": "fade",
            "duration": 300
        },

        "footer": {
            "src": "/storage/tenants/ttt/logo-footer.png",
            "width": 180,
            "height": 60
        },
        "spinner": {
            "src": "/storage/tenants/ttt/logo-spinner.png",
            "width": 80,
            "height": 80
        }
    },

    "radius": {
        "card": "12px",
        "button": "8px"
    }
}
