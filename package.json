{
  "name": "codexsun",
  "private": true,
  "version": "1.0.022",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n cxsun-api,cxsun-web \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch cxsun/src/server.ts",
    "dev:web": "vite --host 127.0.0.1 --port 4173",
    "start:server": "node --import tsx cxsun/src/server.ts",
    "typecheck": "tsc -p tsconfig.frontend.json && tsc -p tsconfig.backend.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "npm run typecheck && vite build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "preview": "vite preview",
    "version:sync": "tsx apps/cli/src/version-helper.ts",
    "github": "tsx apps/cli/src/github-helper.ts",
    "github:now": "tsx apps/cli/src/github-helper.ts --yes"
  },
  "dependencies": {
    "@codexsun/core": "1.0.019",
    "@codexsun/ui": "1.0.019",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/react": "^0.4.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.16",
    "lucide-react": "^1.8.0",
    "mariadb": "^3.5.2",
    "mysql2": "^3.22.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^3.2.4"
  }
}
